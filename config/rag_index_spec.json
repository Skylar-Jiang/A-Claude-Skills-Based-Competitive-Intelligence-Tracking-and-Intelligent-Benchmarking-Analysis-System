{
  "index_version": "tradepilot-pet-supplies-qwen3-embedding-v2",
  "embedding_model": "Qwen/Qwen3-Embedding-0.6B",
  "embedding_dimension": null,
  "product_collection": "product_knowledge",
  "review_collection": "review_insight",
  "product_document_template_version": "product-template-v2",
  "review_document_template_version": "review-template-v1",
  "chunk_config_version": "rag-chunk-v1",
  "metadata_schema_version": "metadata-v2",
  "stable_id_version": "uuid5-source-parent-chunk-v1",
  "content_hash_version": "sha256-v1",
  "normalizer_version": "unicode-html-whitespace-v1",
  "importer_version": "filtered-jsonl-adapter-v2",
  "data_adapter_version": "pet-supplies-filtered-v1",
  "dedup_strategy": "content_hash_document_id_review_id",
  "source_row_locator_strategy": "source_file_name:jsonl_line_number",
  "required_metadata_fields": [
    "document_id",
    "chunk_id",
    "parent_id",
    "chunk_index",
    "content_hash",
    "source_file",
    "source_locator",
    "source_row",
    "knowledge_type",
    "data_origin",
    "is_demo",
    "product_id",
    "parent_asin"
  ],
  "real_demo_marker_rules": {
    "real": {"data_origin": "real", "is_demo": false},
    "demo": {"data_origin": "demo", "is_demo": true}
  },
  "rebuild_triggers": [
    "embedding_model_changed",
    "embedding_dimension_changed",
    "chunk_config_version_changed",
    "document_template_version_changed",
    "metadata_schema_breaking_change",
    "stable_id_version_changed",
    "content_hash_version_changed",
    "collection_name_changed"
  ],
  "compatible_incremental_changes": [
    "non_breaking_metadata_addition",
    "new_source_rows_with_same_versions",
    "content_hash_changed_for_existing_source_row"
  ]
}
