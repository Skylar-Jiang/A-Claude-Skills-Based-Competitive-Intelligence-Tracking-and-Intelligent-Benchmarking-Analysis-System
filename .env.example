# OpenAI-compatible 配置：默认用 DeepSeek 官方兼容网关做低成本连通性测试。
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.deepseek.com/v1

# 如果本地已经按 DeepSeek 命名配置，也会被 OpenAI-compatible 客户端读取。
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 对应老师的模型分层规范：
# fast: 抓取、清洗、关键词提取、轻量分类
# analysis: 结构化分析、竞品对标、工具调用解析
# report: 复杂推理、报告生成、机会/威胁总结
MODEL_FAST=deepseek-v4-flash
MODEL_ANALYSIS=deepseek-v4-pro
MODEL_REPORT=deepseek-v4-pro

# 后续正式使用 GPT 时，改为对应的 OpenAI-compatible 地址、Key 和模型名。
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL_FAST=gpt-4o-mini
# MODEL_ANALYSIS=gpt-4.1
# MODEL_REPORT=gpt-4.1

MODEL_TEMPERATURE=0.0

# 应用接口鉴权。留空表示本地演示不启用鉴权；设置后请求需带 X-API-Key。
APP_API_KEY=

# 第一阶段采集调度开关。演示时可设为 false，避免启动服务后自动访问外部网页。
COLLECTION_SCHEDULER_ENABLED=true
COLLECTION_POLL_SECONDS=300

# RAG 向量化配置。当前已验证模型为 Hugging Face BAAI/bge-small-zh-v1.5。
# 如果 Hugging Face 官方下载不稳定，可保留或替换 HF_ENDPOINT 镜像。
HF_ENDPOINT=https://hf-mirror.com
RAG_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
RAG_EMBEDDING_DEVICE=cpu
RAG_NORMALIZE_EMBEDDINGS=true
